{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildContext": ".",
    "dockerfilePath": "services/$RAILWAY_SERVICE_NAME/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": {
    "umbra": {
      "name": "umbra",
      "build": {
        "builder": "DOCKERFILE",
        "buildContext": ".",
        "dockerfilePath": "services/umbra/Dockerfile"
      },
      "variables": {
        "PORT": "8080",
        "NODE_ENV": "production"
      }
    },
    "finance": {
      "name": "finance",
      "build": {
        "builder": "DOCKERFILE", 
        "buildContext": ".",
        "dockerfilePath": "services/finance/Dockerfile"
      },
      "variables": {
        "PORT": "8081",
        "NODE_ENV": "production"
      }
    },
    "concierge": {
      "name": "concierge",
      "build": {
        "builder": "DOCKERFILE",
        "buildContext": ".",
        "dockerfilePath": "services/concierge/Dockerfile"
      },
      "variables": {
        "PORT": "9090",
        "NODE_ENV": "production"
      }
    },
    "business": {
      "name": "business",
      "build": {
        "builder": "DOCKERFILE",
        "buildContext": ".",
        "dockerfilePath": "services/business/Dockerfile"
      },
      "variables": {
        "PORT": "8082",
        "NODE_ENV": "production"
      }
    },
    "production": {
      "name": "production",
      "build": {
        "builder": "DOCKERFILE",
        "buildContext": ".",
        "dockerfilePath": "services/production/Dockerfile"
      },
      "variables": {
        "PORT": "8083",
        "NODE_ENV": "production"
      }
    },
    "creator": {
      "name": "creator",
      "build": {
        "builder": "DOCKERFILE",
        "buildContext": ".",
        "dockerfilePath": "services/creator/Dockerfile"
      },
      "variables": {
        "PORT": "8084",
        "NODE_ENV": "production"
      }
    },
    "mcp": {
      "name": "mcp",
      "build": {
        "builder": "DOCKERFILE",
        "buildContext": ".",
        "dockerfilePath": "services/mcp/Dockerfile"
      },
      "variables": {
        "PORT": "8085",
        "NODE_ENV": "production"
      }
    }
  }
}