{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildContext": ".",
    "dockerfilePath": "services/$RAILWAY_SERVICE_NAME/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": {
    "umbra": {
      "name": "umbra",
      "build": {
        "builder": "DOCKERFILE",
        "buildContext": ".",
        "dockerfilePath": "services/umbra/Dockerfile"
      },
      "variables": {
        "PORT": "8080",
        "NODE_ENV": "production"
      }
    },
    "finance": {
      "name": "finance",
      "build": {
        "builder": "DOCKERFILE", 
        "buildContext": ".",
        "dockerfilePath": "services/finance/Dockerfile"
      },
      "variables": {
        "PORT": "8081",
        "NODE_ENV": "production"
      }
    },
    "concierge": {
      "name": "concierge",
      "build": {
        "builder": "DOCKERFILE",
        "buildContext": ".",
        "dockerfilePath": "services/concierge/Dockerfile"
      },
      "variables": {
        "PORT": "9090",
        "NODE_ENV": "production"
      }
    }
  }
}