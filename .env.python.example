# Umbra Python Services Environment Configuration
# Copy this file to .env and fill in the actual values

# ==============================================
# GLOBAL CONFIGURATION
# ==============================================

# Environment
PYTHON_ENV=production

# OpenRouter AI Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://umbra.ai

# Storage Configuration (S3/R2 Compatible)
STORAGE_ENDPOINT=https://your-s3-endpoint.com
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_BUCKET=umbra-storage

# ==============================================
# UMBRA MAIN AGENT (PORT 8080)
# ==============================================

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token
WEBHOOK_URL=https://umbra-python-production.railway.app/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# Service API Keys for Internal Communication
FINANCE_API_KEY=secure_finance_key
CONCIERGE_API_KEY=secure_concierge_key
BUSINESS_API_KEY=secure_business_key
PRODUCTION_API_KEY=secure_production_key
CREATOR_API_KEY=secure_creator_key

# Module Base URLs (Railway will provide these)
FINANCE_BASE_URL=https://finance-python-production.railway.app
CONCIERGE_BASE_URL=https://concierge-python-production.railway.app
BUSINESS_BASE_URL=https://business-python-production.railway.app
PRODUCTION_BASE_URL=https://production-python-production.railway.app
CREATOR_BASE_URL=https://creator-python-production.railway.app

# ==============================================
# FINANCE MODULE (PORT 8081)
# ==============================================

# Finance-specific storage
STORAGE_BUCKET_FINANCE=umbra-finance-storage

# Authentication for Umbra service
UMBRA_API_KEY=secure_finance_key

# ==============================================
# CONCIERGE MODULE (PORT 9090)
# ==============================================

# VPS Configuration
VPS_HOST=your_vps_ip
VPS_USERNAME=your_ssh_user
VPS_PRIVATE_KEY=your_ssh_private_key
VPS_PORT=22

# Authentication for Umbra service
UMBRA_API_KEY=secure_concierge_key

# ==============================================
# BUSINESS MODULE (PORT 8082)
# ==============================================

# Authentication for Umbra service
UMBRA_API_KEY=secure_business_key

# ==============================================
# PRODUCTION MODULE (PORT 8083)
# ==============================================

# n8n Configuration
N8N_BASE_URL=https://your-n8n-instance.com
N8N_API_KEY=your_n8n_api_key

# Authentication for Umbra service
UMBRA_API_KEY=secure_production_key

# ==============================================
# CREATOR MODULE (PORT 8084)
# ==============================================

# Media Generation Providers
RUNWAY_API_KEY=your_runway_api_key
SHOTSTACK_API_KEY=your_shotstack_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Storage for generated media
STORAGE_BUCKET_MEDIA=umbra-media-storage

# Authentication for Umbra service
UMBRA_API_KEY=secure_creator_key

# ==============================================
# LOGGING AND MONITORING
# ==============================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Structured logging format
LOG_FORMAT=json

# ==============================================
# SECURITY
# ==============================================

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=*

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ==============================================
# RAILWAY DEPLOYMENT SPECIFIC
# ==============================================

# Railway will automatically set these variables:
# - PORT (service port)
# - RAILWAY_ENVIRONMENT (production, staging, etc.)
# - RAILWAY_PROJECT_ID
# - RAILWAY_SERVICE_ID
# - RAILWAY_DEPLOYMENT_ID

# Health check intervals
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=3s
HEALTH_CHECK_RETRIES=3