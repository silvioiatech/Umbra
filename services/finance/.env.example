# Finance Service Environment Variables

# Server Configuration
PORT=8081
NODE_ENV=production
LOG_LEVEL=info

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Storage Configuration (for document processing)
STORAGE_ENDPOINT=https://your-s3-endpoint.com
STORAGE_ACCESS_KEY=your_access_key_here
STORAGE_SECRET_KEY=your_secret_key_here
STORAGE_BUCKET=umbra-finance-storage
STORAGE_REGION=us-east-1

# Authentication
UMBRA_API_KEY=finance_service_key_here

# Service URLs (for inter-service communication)
UMBRA_URL=http://umbra:8080

# OCR Configuration
OCR_CONFIDENCE_THRESHOLD=0.8
MAX_FILE_SIZE_MB=10

# Financial Processing
PII_MINIMIZATION=true
ENCRYPTION_KEY=your_32_character_encryption_key_here

# CORS Configuration
ALLOWED_ORIGINS=https://your-domain.com

# Security Configuration
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000