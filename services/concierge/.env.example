# VPS Concierge Service Environment Variables

# Server Configuration
PORT=9090
NODE_ENV=production
LOG_LEVEL=info

# VPS Connection Configuration
VPS_HOST=your_vps_ip_address_here
VPS_USERNAME=your_ssh_username_here
VPS_PRIVATE_KEY=your_ssh_private_key_here
VPS_PORT=22
VPS_PASSPHRASE=your_ssh_key_passphrase_here

# SSH Configuration
SSH_TIMEOUT=30000
SSH_KEEPALIVE_INTERVAL=5000
SSH_MAX_CONNECTIONS=5

# Authentication
UMBRA_API_KEY=concierge_service_key_here

# Service URLs (for inter-service communication)
UMBRA_URL=http://umbra:8080

# System Monitoring
MONITOR_INTERVAL=60000
DISK_THRESHOLD=85
MEMORY_THRESHOLD=90
CPU_THRESHOLD=85

# Container Management
DOCKER_SOCKET=/var/run/docker.sock
CONTAINER_PREFIX=umbra_

# Security Configuration
VALIDATION_REQUIRED=true
ALLOWED_COMMANDS=docker,systemctl,ps,df,free,top,htop
FORBIDDEN_PATTERNS=rm -rf,sudo rm,format,mkfs

# CORS Configuration
ALLOWED_ORIGINS=https://your-domain.com

# Audit Logging
AUDIT_LOG_LEVEL=info
AUDIT_RETENTION_DAYS=30

# Rate Limiting
RATE_LIMIT_MAX=50
RATE_LIMIT_WINDOW_MS=900000