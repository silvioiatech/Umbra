# Umbra Main Agent Environment Variables

# Server Configuration
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_URL=https://your-domain.com/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Internal Service API Keys
FINANCE_API_KEY=finance_service_key_here
CONCIERGE_API_KEY=concierge_service_key_here
BUSINESS_API_KEY=business_service_key_here
PRODUCTION_API_KEY=production_service_key_here
CREATOR_API_KEY=creator_service_key_here
MCP_API_KEY=mcp_service_key_here

# Service URLs (for production deployment)
FINANCE_URL=http://finance:8081
CONCIERGE_URL=http://concierge:9090
BUSINESS_URL=http://business:8082
PRODUCTION_URL=http://production:8083
CREATOR_URL=http://creator:8084
MCP_URL=http://mcp:8085

# Storage Configuration
STORAGE_ENDPOINT=https://your-s3-endpoint.com
STORAGE_ACCESS_KEY=your_access_key_here
STORAGE_SECRET_KEY=your_secret_key_here
STORAGE_BUCKET=umbra-storage
STORAGE_REGION=us-east-1

# CORS Configuration
ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# Security Configuration
ALLOWED_USERS=123456789,987654321  # Telegram user IDs (optional)
ENCRYPTION_KEY=your_32_character_encryption_key_here