# Umbra Bot System - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ===================================
# CORE TELEGRAM BOT CONFIGURATION
# ===================================
BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_URL=https://your-railway-app.railway.app/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# ===================================
# OPENROUTER (PRIMARY LLM PROVIDER)
# ===================================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://umbra.ai

# ===================================
# STORAGE (S3/R2 COMPATIBLE)
# ===================================
STORAGE_ENDPOINT=https://your-bucket.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your_r2_access_key
STORAGE_SECRET_KEY=your_r2_secret_key
STORAGE_BUCKET=umbra-production

# ===================================
# VPS CONFIGURATION (CONCIERGE ONLY)
# ===================================
VPS_HOST=your.vps.ip.address
VPS_USERNAME=your_vps_username
VPS_PRIVATE_KEY=your_vps_private_key_content
VPS_PORT=22

# ===================================
# EXTERNAL MCP SERVICE CONFIGURATION
# ===================================
# URL of your externally hosted MCP service
MCP_URL=https://your-external-mcp-service.com
MCP_API_KEY=your_external_mcp_api_key

# ===================================
# MEDIA GENERATION PROVIDERS (OPTIONAL)
# ===================================
RUNWAY_API_KEY=your_runway_api_key_here
SHOTSTACK_API_KEY=your_shotstack_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ===================================
# INTER-SERVICE AUTHENTICATION
# ===================================
# These keys secure communication between Railway services
FINANCE_API_KEY=generate_secure_random_key_here
CONCIERGE_API_KEY=generate_secure_random_key_here
BUSINESS_API_KEY=generate_secure_random_key_here
PRODUCTION_API_KEY=generate_secure_random_key_here
CREATOR_API_KEY=generate_secure_random_key_here

# ===================================
# SERVICE URLS (PRODUCTION ONLY)
# ===================================
# These are automatically configured in Railway, but can be overridden
FINANCE_URL=https://finance-production.railway.app
CONCIERGE_URL=https://concierge-production.railway.app
BUSINESS_URL=https://business-production.railway.app
PRODUCTION_URL=https://production-production.railway.app
CREATOR_URL=https://creator-production.railway.app

# ===================================
# SECURITY & RATE LIMITING
# ===================================
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000
ALLOWED_TELEGRAM_USERS=123456789,987654321

# ===================================
# MONITORING & LOGGING
# ===================================
LOG_LEVEL=info
ENABLE_AUDIT_LOGGING=true
METRICS_ENDPOINT=http://your-metrics-server.com

# ===================================
# ENVIRONMENT CONFIGURATION
# ===================================
NODE_ENV=production
PORT=8080
