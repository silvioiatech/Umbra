{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "umbra-python": {
      "name": "umbra-python",
      "build": {
        "builder": "DOCKERFILE",
        "buildContext": ".",
        "dockerfilePath": "python_services/umbra/Dockerfile"
      },
      "deploy": {
        "numReplicas": 1,
        "sleepApplication": false,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "variables": {
        "PORT": "8080",
        "PYTHON_ENV": "production"
      }
    },
    "finance-python": {
