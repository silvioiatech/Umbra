# Umbra Complete - Environment Configuration
# Copy this file to .env and fill in the actual values

# ==============================================
# CORE CONFIGURATION
# ==============================================

# Server Configuration
PORT=8080
HOST=0.0.0.0

# Environment
PYTHON_ENV=production

# ==============================================
# TELEGRAM BOT CONFIGURATION
# ==============================================

# Required: Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Required: Webhook URL (Railway will provide this)
WEBHOOK_URL=https://your-app-name.railway.app/webhook/telegram

# Optional: Webhook secret for security
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# ==============================================
# AI CONFIGURATION (OpenRouter)
# ==============================================

# Required: OpenRouter API Key for AI functionality
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://umbra.ai

# ==============================================
# STORAGE CONFIGURATION (S3/R2 Compatible)
# ==============================================

# Optional: S3/R2 storage (uses local storage if not provided)
STORAGE_ENDPOINT=https://your-s3-endpoint.com
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_BUCKET=umbra-storage

# ==============================================
# CONCIERGE MODULE (VPS Management)
# ==============================================

# Optional: VPS Configuration for Concierge module
VPS_HOST=your_vps_ip_address
VPS_USERNAME=your_ssh_username
VPS_PRIVATE_KEY=your_ssh_private_key
VPS_PORT=22

# ==============================================
# PRODUCTION MODULE (n8n Integration)
# ==============================================

# Optional: n8n Configuration for workflow management
N8N_BASE_URL=https://your-n8n-instance.com
N8N_API_KEY=your_n8n_api_key

# ==============================================
# CREATOR MODULE (Media Generation)
# ==============================================

# Optional: Media generation providers
RUNWAY_API_KEY=your_runway_api_key
SHOTSTACK_API_KEY=your_shotstack_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Storage for generated media
STORAGE_BUCKET_MEDIA=umbra-media-storage

# ==============================================
# LOGGING AND MONITORING
# ==============================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Structured logging format
LOG_FORMAT=json

# ==============================================
# SECURITY
# ==============================================

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=*

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ==============================================
# RAILWAY DEPLOYMENT SPECIFIC
# ==============================================

# Railway will automatically set these variables:
# - PORT (service port)
# - RAILWAY_ENVIRONMENT (production, staging, etc.)
# - RAILWAY_PROJECT_ID
# - RAILWAY_SERVICE_ID
# - RAILWAY_DEPLOYMENT_ID

# Health check configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=3s
HEALTH_CHECK_RETRIES=3

# ==============================================
# MINIMAL SETUP FOR BASIC FUNCTIONALITY
# ==============================================

# For basic chat and help functionality, only these are required:
# 1. BOT_TOKEN - Get from @BotFather on Telegram
# 2. WEBHOOK_URL - Set to your Railway app URL + /webhook/telegram

# For AI-powered features, also add:
# 3. OPENROUTER_API_KEY - Get from openrouter.ai

# All other configuration is optional and enables additional features